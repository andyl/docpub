#!/usr/bin/env elixir

# Standalone launcher for the Docpub vault viewer server.
#
# Mirrors the command-line interface of `mix docpub.serve` but does not
# require an active Mix project — it pulls Docpub in via `Mix.install/2`.
#
# Usage:
#
#     scripts/docpub_serve <vault_path> [options]
#
# vault_path is required; pass `.` to serve the current directory.
# Run with `--help` for the full option list.
#
# By default this references the surrounding repository via a path
# dependency. To launch from a different checkout, edit the `:docpub`
# entry below (path:, git:, or hex version) to taste.

docpub_path = Path.expand("..", __DIR__)

# --- Phase 1: argument parsing ----------------------------------------------
#
# We deliberately parse argv BEFORE calling Mix.install/2. Mix.install starts
# the :docpub OTP application as a side effect of loading the dep, which in
# turn starts VaultWatcher and other supervisors. For `--help` and `--version`
# we don't want any of that to run, so we handle those branches here using
# only stdlib (OptionParser) and exit before touching Mix.install at all.
#
# The switches list is intentionally a small duplication of
# `Docpub.Server.switches/0` — we can't reference Docpub.Server until after
# Mix.install has loaded the dep.

switches = [
  port: :integer,
  host: :string,
  password: :string,
  initial_page: :string,
  title: :string,
  help: :boolean,
  version: :boolean
]

{opts, positional, _} = OptionParser.parse(System.argv(), switches: switches)

show_help = fn ->
  IO.puts("""
  Starts the Docpub vault viewer server.

  Usage:

      scripts/docpub_serve <vault_path> [options]

  vault_path is required. Pass `.` to serve the current directory.
  Running with no arguments prints this help message.

  Options:

    --port           Port to listen on (default: 4000)
    --host           Host to bind to (default: 127.0.0.1)
    --password       Require password authentication (open access if omitted)
    --initial-page   Initial page to display (e.g., README)
    --title          Site title shown in the header and browser tab (default: Docpub)
    --help           Show this help message
    --version        Show version

  Examples:

      scripts/docpub_serve .
      scripts/docpub_serve ~/my-vault
      scripts/docpub_serve ~/my-vault --port 8080
      scripts/docpub_serve ~/my-vault --title "My Notes"
  """)
end

cond do
  opts[:help] ->
    show_help.()
    System.halt(0)

  opts[:version] ->
    # Read version straight out of mix.exs so we don't have to load the app.
    version =
      with {:ok, content} <- File.read(Path.join(docpub_path, "mix.exs")),
           [_, v] <- Regex.run(~r/@version\s+"([^"]+)"/, content) do
        v
      else
        _ -> "unknown"
      end

    IO.puts("Docpub v#{version}")
    System.halt(0)

  positional == [] ->
    show_help.()
    System.halt(0)

  true ->
    :run
end

# --- Phase 2: load Docpub via Mix.install -----------------------------------
#
# Only reached when we're actually going to start the server.

Mix.install(
  [
    {:docpub, path: docpub_path}
  ],
  config: [
    phoenix: [json_library: Jason],
    docpub: [
      {DocpubWeb.Endpoint,
       url: [host: "localhost"],
       http: [ip: {127, 0, 0, 1}, port: 4000],
       adapter: Bandit.PhoenixAdapter,
       render_errors: [
         formats: [html: DocpubWeb.ErrorHTML, json: DocpubWeb.ErrorJSON],
         layout: false
       ],
       pubsub_server: Docpub.PubSub,
       live_view: [signing_salt: "z4X1F9SI"],
       # Dev secret — fine for a local read-only doc viewer. Override
       # by exporting SECRET_KEY_BASE before launching.
       secret_key_base:
         System.get_env("SECRET_KEY_BASE") ||
           "WY/8gniTxM4C8onrO0VHqyxPxNJZatO6rkdW8SHt7o/QPDh9fF/OaP7vmPsD+NY7xK",
       check_origin: false},
      generators: [timestamp_type: :utc_datetime],
      vault_path: nil,
      initial_page: nil,
      password: nil,
      title: nil
    ]
  ],
  # Do NOT start :docpub here. Server.configure/2 needs to write
  # endpoint options (server: true, port, ip) into the application
  # env *before* the endpoint boots — otherwise the HTTP listener
  # is never started and the browser sees ERR_FAILED.
  start_applications: false
)

alias Docpub.Server

# Force-load :docpub *before* mutating its app env. Application.load/1
# reads the env block out of the dep's .app file into the global app env,
# which would clobber any put_env calls made earlier. Application.start/1
# (and ensure_all_started/1) call load/1 implicitly when the app is not
# already loaded, so do it explicitly here to control ordering:
# load → put_env → start.
Application.stop(:docpub)
Application.unload(:docpub)
:ok = Application.load(:docpub)

# Resolve secret_key_base. Plug 1.19+ requires at least 64 bytes for the
# cookie session store; if the operator's environment exports something
# shorter (e.g. a placeholder like SECRET_KEY_BASE=foo) we ignore it with
# a warning rather than booting an endpoint that 500s on every request.
fallback_secret_key_base =
  "WY/8gniTxM4C8onrO0VHqyxPxNJZatO6rkdW8SHt7o/QPDh9fF/OaP7vmPsD+NY7xK"

secret_key_base =
  case System.get_env("SECRET_KEY_BASE") do
    nil ->
      fallback_secret_key_base

    value when byte_size(value) >= 64 ->
      value

    short ->
      IO.puts(
        :stderr,
        "warning: ignoring SECRET_KEY_BASE — only #{byte_size(short)} bytes, " <>
          "Plug requires at least 64. Using built-in dev fallback."
      )

      fallback_secret_key_base
  end

endpoint_config = Application.get_env(:docpub, DocpubWeb.Endpoint, [])

Application.put_env(
  :docpub,
  DocpubWeb.Endpoint,
  Keyword.put(endpoint_config, :secret_key_base, secret_key_base)
)

case Server.configure(opts, positional) do
  {:ok, info} ->
    IO.puts("Starting Docpub server...")
    IO.puts("  Vault: #{info.vault_path}")
    IO.puts("  URL:   http://#{info.host}:#{info.port}")

    {:ok, _} = Application.ensure_all_started(:docpub)
    Process.sleep(:infinity)

  {:error, message} ->
    IO.puts(:stderr, "Error: #{message}")
    System.halt(1)
end
